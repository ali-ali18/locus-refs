{
  "name": "refstash-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @refstash/web dev",
    "build": "pnpm --filter @refstash/web build",
    "start": "prisma migrate deploy && pnpm --filter @refstash/web start",
    "collab:dev": "pnpm --filter @refstash/collab dev",
    "lint": "biome check",
    "format": "biome format --write",
    "test": "pnpm --filter @refstash/web test",
    "test:run": "pnpm --filter @refstash/web test:run",
    "commit": "cz",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "config": {
    "commitizen": {
      "path": "./.cz-config.js"
    }
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "dotenv": "^17.3.1",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "commitizen": "^4.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prisma": "^7.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
