generator client {
  provider = "prisma-client"
  output   = "../apps/web/src/generated/prisma"
}

generator collab_client {
  provider = "prisma-client"
  output   = "../apps/collab/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sessions      Session[]
  accounts      Account[]
  collections   Collection[]
  categories    Category[]
  notes         Note[]
  members       Member[]
  invitations   Invitation[]

  @@unique([email])
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Collection {
  id             String       @id @default(uuid())
  name           String
  slug           String
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId    String
  workspace      Organization @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  resources      Resource[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  notes          Note[]

  @@unique([workspaceId, slug])
}

model Resource {
  id           String     @id @default(uuid())
  title        String
  description  String?
  url          String
  iconUrl      String?
  ogImageUrl   String?
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  categories   Category[] @relation("ResourceCategories")
  fetchedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([url, collectionId])
}

model Category {
  id          String       @id @default(uuid())
  name        String
  slug        String
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Organization @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  resources   Resource[]   @relation("ResourceCategories")

  @@unique([name, workspaceId])
  @@unique([slug, workspaceId])
}

model Note {
  id           String       @id @default(uuid())
  title        String
  icon         String?
  content      String       @db.Text
  collectionId String?
  collection   Collection?  @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId  String
  workspace    Organization @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ydoc         Bytes?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  linkedTo   NoteLink[] @relation("source")
  linkedFrom NoteLink[] @relation("target")
}

model NoteLink {
  sourceId  String
  targetId  String
  source    Note     @relation("source", fields: [sourceId], references: [id], onDelete: Cascade)
  target    Note     @relation("target", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([sourceId, targetId])
}

model Organization {
  id          String       @id
  name        String
  slug        String
  logo        String?
  createdAt   DateTime
  metadata    String?
  members     Member[]
  invitations Invitation[]
  collections Collection[]
  categories  Category[]
  notes       Note[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}
